# ============================================================
# Blog Backend — Environment Variables
# ============================================================
# Copiá este archivo a .env y completá los valores

# Servidor
PORT=4000
NODE_ENV=development

# MongoDB
# Local: mongodb://localhost:27017/blog
# Atlas: mongodb+srv://<user>:<password>@<cluster>/blog
MONGO_URI=mongodb+srv://kloster_dev:TeamoEsmeralda13@blog.66v0hxy.mongodb.net/blog?appName=Blog


# JWT — Generá una clave segura con: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-32-char-secret-minimum
JWT_EXPIRES_IN=7d

# Cloudinary — Obtené credenciales en https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Carpeta temporal para uploads (crear la carpeta 'uploads' si no existe)
UPLOAD_TMP_DIR=./uploads
